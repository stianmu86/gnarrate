# Narrate — Supabase Edge Function Secrets
# Set via Dashboard -> Project Settings -> Secrets (NOT committed to repo).
# This file is a reference only — do NOT create a .env.supabase with real values.
#
# ⚠️  Edge Functions use SUPABASE_SERVICE_ROLE_KEY (bypasses RLS).
#     The Expo client uses EXPO_PUBLIC_SUPABASE_ANON_KEY (RLS enforced).
#     NEVER swap these.

SUPABASE_SERVICE_ROLE_KEY=eyJ...
MODAL_API_KEY=ak-...
MODAL_NARRATE_ENDPOINT=https://xxxx.modal.run/generate-audio
MODAL_ANALYZE_ENDPOINT=https://xxxx.modal.run/analyze-text
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
